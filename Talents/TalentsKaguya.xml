    <Talent identifier="Touhou_Kaguya_Treasure_Fire_Lizard_Shield_Talent" IsHiddenExtraTalent="true" >
        <Icon texture="%ModDir%/Images/Talents/KaguyaTalent.png" sheetindex="0,0" sheetelementsize="128,128"/>
        <Description tag="talentdescription.Touhou_Kaguya_Treasure_Fire_Lizard_Shield_Talent"/>
        <AbilityGroupInterval Interval="5.0">
            <Conditions>
                <AbilityConditionHasAffliction afflictionidentifier="Sinner_Of_Eternity_And_The_Ephemeral"/>
                <AbilityConditionHasItem tags="Touhou_Kaguya_Treasure_Fire_Lizard_Shield"/>
            </Conditions>
            <Abilities>
                <CharacterAbilityModifyResistance resistanceid="burn" multiplier="0.9"/>
            </Abilities>
        </AbilityGroupInterval>
        <AbilityGroupEffect abilityeffecttype="OnAddDamageAffliction">
            <Conditions>
                <AbilityConditionHasAffliction afflictionidentifier="Sinner_Of_Eternity_And_The_Ephemeral"/>
                <AbilityConditionHasItem tags="Touhou_Kaguya_Treasure_Fire_Lizard_Shield"/>
            </Conditions>
            <Abilities>
                <CharacterAbilityModifyAffliction afflictionidentifiers="burn" addedmultiplier="0.1"/>
            </Abilities>
        </AbilityGroupEffect>
        <AbilityGroupInterval interval="3.0">
            <Conditions>
                <AbilityConditionHasAffliction afflictionidentifier="Sinner_Of_Eternity_And_The_Ephemeral"/>
                <AbilityConditionHasItem tags="Touhou_Kaguya_Treasure_Fire_Lizard_Shield"/>
            </Conditions>
            <Abilities>
                <CharacterAbilityApplyStatusEffects SetUser="false">
                    <StatusEffects>
                        <StatusEffect type="OnAbility" target="Character" disabledeltatime="true">
                            <ReduceAffliction type="burn" amount="0.3"/>
                        </StatusEffect>
                    </StatusEffects>
                </CharacterAbilityApplyStatusEffects>
            </Abilities>
        </AbilityGroupInterval>
        <AbilityGroupInterval interval="3.0">
            <Conditions>
                <AbilityConditionHasAffliction afflictionidentifier="Sinner_Of_Eternity_And_The_Ephemeral"/>
                <AbilityConditionInSubmarine submarinetype="Player" />
            </Conditions>
            <Abilities>
                <CharacterAbilityModifyStat stattype="SkillGainSpeed" value="0.25"/>
            </Abilities>
        </AbilityGroupInterval>
    </Talent>

