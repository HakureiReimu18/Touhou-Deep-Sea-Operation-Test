        <Description tag="talentdescription.KaguyaTalent"/>
        <AbilityGroupInterval Interval="5.0">
            <Conditions>
                <AbilityConditionHasAffliction afflictionidentifier="Sinner_Of_Eternity_And_The_Ephemeral"/>
            </Conditions>
            <Abilities>
                <CharacterAbilityModifyResistance resistanceid="bleeding" multiplier="0.75"/>
